# ==========================================================================
# This is a template. Copy to `.env` and fill in real values for local dev.
# Production values are set in the Render dashboard, not in this file.
# ==========================================================================

# App
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database — Supabase Postgres (same URL for local + prod).
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Redis
# - Local docker-compose: redis://redis:6379/0
# - Production (Upstash):  rediss://default:TOKEN@HOST.upstash.io:6379
REDIS_URL=redis://redis:6379/0

# Qdrant
# - Local docker-compose: http://qdrant:6333  (leave QDRANT_API_KEY empty)
# - Production (Qdrant Cloud): https://CLUSTER.cloud.qdrant.io  (set API key)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=knowledge_base

# AI services (Groq covers both LLM and Whisper transcription)
GROQ_API_KEY=your-groq-api-key-here
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=llama-3.1-70b-versatile
WHISPER_MODEL=whisper-large-v3
RAG_TOP_K=5
RAG_CONFIDENCE_THRESHOLD=0.6

# Supabase Storage (for audio uploads — required in both local and prod)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=supabucket

# Internal API key — shared between the backend and the GitHub Actions cron job.
# Generate a random string, set it here AND as a GitHub Actions secret (INTERNAL_API_KEY).
INTERNAL_API_KEY=change-this-to-a-random-string

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
